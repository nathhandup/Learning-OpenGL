{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build OpenGL",
      "type": "shell",
      "command": "g++",
      "args": [
        "src/examples/main.cpp",
        "src/glad.c",
        "-Iinclude",
        "-Llib",
        "-lglfw3",
        "-lopengl32",
        "-lgdi32",
        "-o",
        "main.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}